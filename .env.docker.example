# ============================================================
# .env.docker — Docker 部署环境变量模板
# 使用方式：cp .env.docker.example .env.docker，然后填写实际值
# ============================================================

# ── Django 核心 ──────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
SYSTEM_TITLE=Hyself 管理后台

# 允许访问的域名 / IP，多个用逗号分隔（不要加空格）
ALLOWED_HOSTS=your-server-ip,your-domain.com

# CORS（如前端与后端同域，可改为 False 并配置白名单）
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOW_CREDENTIALS=False

# ── 数据库（指向 db 容器服务名） ────────────────────────────
DATABASE_HOST=db
DATABASE_PORT=3306
DATABASE_NAME=hyself_db
DATABASE_USER=hyself
DATABASE_PASSWORD=your_db_password

# ── MySQL root 密码（仅 docker-compose 启动 db 容器时使用） ──
MYSQL_ROOT_PASSWORD=your_mysql_root_password

# ── Redis（指向 redis 容器服务名） ──────────────────────────
CHANNEL_REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/2
CELERY_RESULT_BACKEND=redis://redis:6379/3
